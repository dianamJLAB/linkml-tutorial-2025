        <https://w3id.org/narad_linkml/schema/narad/schema/:ElementKindEnum> .

<https://w3id.org/narad_linkml/schema/narad/schema/:ElementKindEnum#Solenoid> a owl:Class ;
    rdfs:label "Solenoid" ;
    rdfs:subClassOf linkml:PermissibleValue,
        <https://w3id.org/narad_linkml/schema/narad/schema/:ElementKindEnum> .

<https://w3id.org/narad_linkml/schema/narad/schema/:RelationshipTypeEnum#BINDS_TO> a owl:Class ;
    rdfs:label "BINDS_TO" ;
    rdfs:subClassOf linkml:PermissibleValue,
        <https://w3id.org/narad_linkml/schema/narad/schema/:RelationshipTypeEnum> .

<https://w3id.org/narad_linkml/schema/narad/schema/:RelationshipTypeEnum#CONTROLLED_BY> a owl:Class ;
    rdfs:label "CONTROLLED_BY" ;
    rdfs:subClassOf linkml:PermissibleValue,
        <https://w3id.org/narad_linkml/schema/narad/schema/:RelationshipTypeEnum> .

<https://w3id.org/narad_linkml/schema/narad/schema/:RelationshipTypeEnum#HAS_SHARED_CAPABILITY> a owl:Class ;
    rdfs:label "HAS_SHARED_CAPABILITY" ;
    rdfs:subClassOf linkml:PermissibleValue,
        <https://w3id.org/narad_linkml/schema/narad/schema/:RelationshipTypeEnum> .

<https://w3id.org/narad_linkml/schema/narad/schema/:RelationshipTypeEnum#HAS_SIGNAL> a owl:Class ;
    rdfs:label "HAS_SIGNAL" ;
