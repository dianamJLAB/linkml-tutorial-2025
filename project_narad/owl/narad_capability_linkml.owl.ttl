        ncit:C47840,
        ncit:C48150,
        ncit:C48870,
        ncit:C48871,
        ncit:C95630,
        ncit:C95637 .

<https://w3id.org/narad_linkml/schema/narad/schema/:RelationshipTypeEnum> a owl:Class ;
