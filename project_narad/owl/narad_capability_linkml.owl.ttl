    skos:inScheme <https://w3id.org/narad_linkml/schema/narad/schema> .

<https://w3id.org/narad_linkml/schema/narad/schema> a owl:Ontology ;
    rdfs:label "narad" ;
    dcterms:license "CC-BY-4.0" ;
    pav:version "0.1.0" ;
    skos:definition "NARAD extension for capability-layer semantics and facility-specific signal bindings" .

