        <https://w3id.org/narad_linkml/schema/narad/schema/:RelationshipTypeEnum> .

<https://w3id.org/narad_linkml/schema/narad/schema/:RelationshipTypeEnum#HAS_TYPE_PROFILE> a owl:Class ;
    rdfs:label "HAS_TYPE_PROFILE" ;
    rdfs:subClassOf linkml:PermissibleValue,
        <https://w3id.org/narad_linkml/schema/narad/schema/:RelationshipTypeEnum> .

<https://w3id.org/narad_linkml/schema/narad/schema/:RelationshipTypeEnum#HAS_TYPE_SPECIFIC_CAPABILITY> a owl:Class ;
