    rdfs:subClassOf linkml:EnumDefinition ;
    owl:unionOf ( ncit:C45255 ncit:C47840 ncit:C48150 ncit:C48870 ncit:C45253 ncit:C45254 ncit:C95630 ncit:C48871 ncit:C95637 ) ;
    skos:definition "Allowed data types for signal values." ;
