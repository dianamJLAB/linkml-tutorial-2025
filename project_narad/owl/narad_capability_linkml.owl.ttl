    rdfs:subClassOf linkml:PermissibleValue,
        <https://w3id.org/narad_linkml/schema/narad/schema/:RelationshipTypeEnum> .

<https://w3id.org/narad_linkml/schema/narad/schema/:RelationshipTypeEnum#IMPLEMENTED_BY> a owl:Class ;
