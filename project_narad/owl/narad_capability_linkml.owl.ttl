@prefix sosa: <http://www.w3.org/ns/sosa/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<https://w3id.org/narad_linkml/schema/narad/schema/NaradModel> a owl:Class ;
    rdfs:label "NaradModel" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://w3id.org/narad_linkml/schema/narad/schema/beamlines> ],
        [ a owl:Restriction ;
            owl:allValuesFrom <https://w3id.org/narad_linkml/schema/narad/schema/Beamline> ;
            owl:onProperty <https://w3id.org/narad_linkml/schema/narad/schema/beamlines> ],
        [ a owl:Restriction ;
            owl:allValuesFrom <https://w3id.org/narad_linkml/schema/narad/schema/NaradConfig> ;
            owl:onProperty <https://w3id.org/narad_linkml/schema/narad/schema/narad> ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://w3id.org/narad_linkml/schema/narad/schema/narad> ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://w3id.org/narad_linkml/schema/narad/schema/elements> ],
        [ a owl:Restriction ;
            owl:allValuesFrom <https://w3id.org/narad_linkml/schema/narad/schema/BeamlineElement> ;
            owl:onProperty <https://w3id.org/narad_linkml/schema/narad/schema/elements> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://w3id.org/narad_linkml/schema/narad/schema/narad> ],
        linkml:ClassDefinition ;
    skos:definition "Top-level NARAD document container." ;
    skos:inScheme <https://w3id.org/narad_linkml/schema/narad/schema> .

<https://w3id.org/narad_linkml/schema/narad/schema/class> a owl:DatatypeProperty ;
    rdfs:label "class" ;
    rdfs:range xsd:string ;
    skos:definition "Class label used in profile payloads (for example, QuadrupoleStrengthCapability)." ;
    skos:inScheme <https://w3id.org/narad_linkml/schema/narad/schema> .

<https://w3id.org/narad_linkml/schema/narad/schema/ElementNaradRef> a owl:Class ;
    rdfs:label "ElementNaradRef" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://w3id.org/narad_linkml/schema/narad/schema/cavity_semantics> ],
        [ a owl:Restriction ;
            owl:allValuesFrom <https://w3id.org/narad_linkml/schema/narad/schema/ElementSemantics> ;
            owl:onProperty <https://w3id.org/narad_linkml/schema/narad/schema/instrument_semantics> ],
        [ a owl:Restriction ;
            owl:allValuesFrom <https://w3id.org/narad_linkml/schema/narad/schema/CapabilityProfile> ;
            owl:onProperty <https://w3id.org/narad_linkml/schema/narad/schema/capability_profile> ],
        [ a owl:Restriction ;
            owl:allValuesFrom <https://w3id.org/narad_linkml/schema/narad/schema/ElementSemantics> ;
            owl:onProperty <https://w3id.org/narad_linkml/schema/narad/schema/magnet_semantics> ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://w3id.org/narad_linkml/schema/narad/schema/capability_profile> ],
        [ a owl:Restriction ;
            owl:allValuesFrom <https://w3id.org/narad_linkml/schema/narad/schema/PVBinding> ;
            owl:onProperty <https://w3id.org/narad_linkml/schema/narad/schema/signal_bindings> ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://w3id.org/narad_linkml/schema/narad/schema/instrument_semantics> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://w3id.org/narad_linkml/schema/narad/schema/magnet_semantics> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://w3id.org/narad_linkml/schema/narad/schema/capability_profile_family> ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://w3id.org/narad_linkml/schema/narad/schema/capability_profile_family> ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://w3id.org/narad_linkml/schema/narad/schema/magnet_semantics> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://w3id.org/narad_linkml/schema/narad/schema/cavity_semantics> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://w3id.org/narad_linkml/schema/narad/schema/instrument_semantics> ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://w3id.org/narad_linkml/schema/narad/schema/signal_bindings> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://w3id.org/narad_linkml/schema/narad/schema/capability_profile> ],
        [ a owl:Restriction ;
            owl:allValuesFrom <https://w3id.org/narad_linkml/schema/narad/schema/ControlProfileFamily> ;
            owl:onProperty <https://w3id.org/narad_linkml/schema/narad/schema/capability_profile_family> ],
        [ a owl:Restriction ;
            owl:allValuesFrom <https://w3id.org/narad_linkml/schema/narad/schema/ElementSemantics> ;
            owl:onProperty <https://w3id.org/narad_linkml/schema/narad/schema/cavity_semantics> ],
        linkml:ClassDefinition ;
    skos:definition "NARAD semantic reference block attached to a beamline element." ;
    skos:inScheme <https://w3id.org/narad_linkml/schema/narad/schema> .

<https://w3id.org/narad_linkml/schema/narad/schema/PVBinding> a owl:Class ;
    rdfs:label "PVBinding" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://w3id.org/narad_linkml/schema/narad/schema/control_system> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://w3id.org/narad_linkml/schema/narad/schema/name> ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty <https://w3id.org/narad_linkml/schema/narad/schema/name> ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty <https://w3id.org/narad_linkml/schema/narad/schema/pv> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://w3id.org/narad_linkml/schema/narad/schema/control_system> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://w3id.org/narad_linkml/schema/narad/schema/pv> ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty <https://w3id.org/narad_linkml/schema/narad/schema/name> ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://w3id.org/narad_linkml/schema/narad/schema/facility> ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty <https://w3id.org/narad_linkml/schema/narad/schema/facility> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://w3id.org/narad_linkml/schema/narad/schema/facility> ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty <https://w3id.org/narad_linkml/schema/narad/schema/control_system> ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://w3id.org/narad_linkml/schema/narad/schema/pv> ],
        linkml:ClassDefinition ;
    skos:definition "A concrete PV (Process Variable) binding for one semantic signal on a beamline element." ;
    skos:inScheme <https://w3id.org/narad_linkml/schema/narad/schema> .

ncit:C45253 a owl:Class ;
    rdfs:label "string" ;
    rdfs:subClassOf linkml:PermissibleValue,
        <https://w3id.org/narad_linkml/schema/narad/schema/:DataTypeEnum> ;
    skos:definition "A sequence of characters used to represent text." .

ncit:C45254 a owl:Class ;
    rdfs:label "boolean" ;
    rdfs:subClassOf linkml:PermissibleValue,
        <https://w3id.org/narad_linkml/schema/narad/schema/:DataTypeEnum> ;
    skos:definition "A data type with two possible values: true and false." .

ncit:C45255 a owl:Class ;
    rdfs:label "None" ;
    rdfs:subClassOf linkml:PermissibleValue,
        <https://w3id.org/narad_linkml/schema/narad/schema/:DataTypeEnum> ;
    skos:definition "A special value that may represent an unknown, missing, not applicable, or undefined value." .

ncit:C47840 a owl:Class ;
    rdfs:label "int" ;
    rdfs:subClassOf linkml:PermissibleValue,
        <https://w3id.org/narad_linkml/schema/narad/schema/:DataTypeEnum> ;
    skos:definition "A data type comprised of numbers with no fractional part, including negative and positive values." .

ncit:C48150 a owl:Class ;
    rdfs:label "float" ;
    rdfs:subClassOf linkml:PermissibleValue,
        <https://w3id.org/narad_linkml/schema/narad/schema/:DataTypeEnum> ;
    skos:definition "A number that can have its decimal point in any position." .

ncit:C48870 a owl:Class ;
    rdfs:label "double" ;
    rdfs:subClassOf linkml:PermissibleValue,
        <https://w3id.org/narad_linkml/schema/narad/schema/:DataTypeEnum> ;
    skos:definition "A 64-bit floating-point value." .

ncit:C48871 a owl:Class ;
    rdfs:label "date" ;
    rdfs:subClassOf linkml:PermissibleValue,
        <https://w3id.org/narad_linkml/schema/narad/schema/:DataTypeEnum> ;
    skos:definition "A calendar date (year, month, day)." .

ncit:C95630 a owl:Class ;
    rdfs:label "boolean_non_null" ;
    rdfs:subClassOf linkml:PermissibleValue,
        <https://w3id.org/narad_linkml/schema/narad/schema/:DataTypeEnum> ;
    skos:definition "A two-value boolean data type that does not include null flavor." .

ncit:C95637 a owl:Class ;
    rdfs:label "coded_value" ;
    rdfs:subClassOf linkml:PermissibleValue,
        <https://w3id.org/narad_linkml/schema/narad/schema/:DataTypeEnum> ;
    skos:definition "A code value referenced from an external coding system or ontology." .

<https://w3id.org/narad_linkml/schema/narad/schema/:ElementKindEnum#BPM> a owl:Class ;
    rdfs:label "BPM" ;
    rdfs:subClassOf linkml:PermissibleValue,
        <https://w3id.org/narad_linkml/schema/narad/schema/:ElementKindEnum> .

<https://w3id.org/narad_linkml/schema/narad/schema/:ElementKindEnum#Corrector> a owl:Class ;
    rdfs:label "Corrector" ;
    rdfs:subClassOf linkml:PermissibleValue,
        <https://w3id.org/narad_linkml/schema/narad/schema/:ElementKindEnum> .

<https://w3id.org/narad_linkml/schema/narad/schema/:ElementKindEnum#Dipole> a owl:Class ;
    rdfs:label "Dipole" ;
    rdfs:subClassOf linkml:PermissibleValue,
        <https://w3id.org/narad_linkml/schema/narad/schema/:ElementKindEnum> .

<https://w3id.org/narad_linkml/schema/narad/schema/:ElementKindEnum#Drift> a owl:Class ;
    rdfs:label "Drift" ;
    rdfs:subClassOf linkml:PermissibleValue,
        <https://w3id.org/narad_linkml/schema/narad/schema/:ElementKindEnum> .

<https://w3id.org/narad_linkml/schema/narad/schema/:ElementKindEnum#Instrument> a owl:Class ;
    rdfs:label "Instrument" ;
    rdfs:subClassOf linkml:PermissibleValue,
        <https://w3id.org/narad_linkml/schema/narad/schema/:ElementKindEnum> .

<https://w3id.org/narad_linkml/schema/narad/schema/:ElementKindEnum#Marker> a owl:Class ;
    rdfs:label "Marker" ;
    rdfs:subClassOf linkml:PermissibleValue,
        <https://w3id.org/narad_linkml/schema/narad/schema/:ElementKindEnum> .

<https://w3id.org/narad_linkml/schema/narad/schema/:ElementKindEnum#Quadrupole> a owl:Class ;
    rdfs:label "Quadrupole" ;
    rdfs:subClassOf linkml:PermissibleValue,
        <https://w3id.org/narad_linkml/schema/narad/schema/:ElementKindEnum> .

<https://w3id.org/narad_linkml/schema/narad/schema/:ElementKindEnum#RFCavity> a owl:Class ;
